# Copy to .env for local development. On Railway, set these in the Variables tab.

# ── Required ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Required in production. Railway gives you a domain like
# https://your-app.up.railway.app
PUBLIC_URL=

# ── MCP (Claude → Telegram direction) ────────────────────────────────────────
# Set to any long random string to enable the MCP endpoint at
#   <PUBLIC_URL>/mcp-<MCP_SECRET>/mcp
# Use the same value when adding the custom connector in Claude. Leave unset
# to disable MCP and run the bot in Telegram-only mode.
MCP_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
# SYSTEM_PROMPT=You are a helpful assistant talking to a user over Telegram...
MAX_HISTORY_TURNS=10
MAX_TOKENS=1024

# Telegram echoes this back on every webhook for auth. Recommended.
# WEBHOOK_SECRET=some-long-random-string

# Numeric chat_id to push to before the bot has been /started. Auto-learned
# from /start otherwise.
# OWNER_CHAT_ID=

# Override SQLite path. Defaults to /data/bot.db if a Railway volume is mounted
# at /data, else ./bot.db (ephemeral).
# DB_PATH=
