# Copy to .env for local development. On Railway, set these in the Variables tab instead.

# Required
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Required in production (Railway). Leave empty locally to use long polling.
# Railway gives you a public domain like https://your-app.up.railway.app
PUBLIC_URL=

# Optional
CLAUDE_MODEL=claude-sonnet-4-6
# SYSTEM_PROMPT=You are a helpful assistant talking to a user over Telegram...
MAX_HISTORY_TURNS=10
MAX_TOKENS=1024

# Optional: random string Telegram will echo back on each webhook for auth.
# WEBHOOK_SECRET=some-long-random-string
